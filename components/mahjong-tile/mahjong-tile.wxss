/* components/mahjong-tile/mahjong-tile.wxss */

/* 基础麻将牌样式 */
.mahjong-tile {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 134rpx;
  height: 200rpx;
  background: white;
  border: 2rpx solid #333;
  border-radius: 8rpx;
  box-shadow: 2rpx 2rpx 4rpx rgba(0, 0, 0, 0.2);
  transition: all 0.3s ease;
  cursor: pointer;
}

/* 禁用状态 */
.mahjong-tile.disabled {
  opacity: 0.5;
  pointer-events: none;
}

/* 精灵图容器样式 */
.sprite-container {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 100%;
  background-color: #f8f8f8;
  border-radius: 6rpx;
  overflow: hidden;
}

/* 精灵图样式 */
.tile-sprite {
  background-size: auto;
  background-repeat: no-repeat;
  border-radius: 6rpx;
  box-shadow: inset 0 0 2rpx rgba(0, 0, 0, 0.3);
  transition: all 0.2s ease;
  position: relative;
}

/* 精灵图悬停效果 */
.mahjong-tile:not(.disabled):hover .tile-sprite {
  transform: scale(1.05);
  box-shadow: inset 0 0 4rpx rgba(0, 0, 0, 0.5);
}

/* 精灵图点击效果 */
.mahjong-tile:not(.disabled):active .tile-sprite {
  transform: scale(0.95);
  box-shadow: inset 0 0 6rpx rgba(0, 0, 0, 0.7);
}

/* 响应式调整 */
@media screen and (max-width: 375px) {
  .mahjong-tile {
    width: 100rpx;
    height: 150rpx;
  }
  
  .tile-sprite {
    background-size: auto !important;
  }
}

@media screen and (min-width: 768px) {
  .mahjong-tile {
    width: 160rpx;
    height: 240rpx;
  }
  
  .tile-sprite {
    background-size: auto !important;
  }
}

/* 单张图片样式 */
.tile-image {
  width: 90%;
  height: 90%;
  border-radius: 6rpx;
  object-fit: contain;
}

/* 精灵图样式 */
.tile-sprite {
  background-size: auto;
  background-repeat: no-repeat;
  border-radius: 6rpx;
  box-shadow: inset 0 0 2rpx rgba(0, 0, 0, 0.3);
  transition: all 0.2s ease;
  position: relative;
  width: 100%;
  height: 100%;
}

/* 点击效果 */
.mahjong-tile:active {
  transform: scale(0.95);
  box-shadow: 1rpx 1rpx 2rpx rgba(0, 0, 0, 0.1);
}

/* 自定义类名 */
.mahjong-tile.custom {
  /* 允许外部自定义样式 */
}