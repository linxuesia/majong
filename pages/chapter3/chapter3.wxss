/* 第三章样式 */
.container {
  min-height: 100vh;
  padding: 32rpx;
  display: flex;
  flex-direction: column;
  animation: fadeIn 0.8s ease-out;
}

.guide-section {
  display: flex;
  align-items: flex-start;
  margin-bottom: 32rpx;
  animation: slideIn 0.8s ease-out 0.2s both;
}

.guide-avatar {
  width: 100rpx;
  height: 100rpx;
  margin-right: 16rpx;
  border-radius: 50%;
  box-shadow: 0 4rpx 16rpx rgba(211, 47, 47, 0.3);
  background: linear-gradient(135deg, #D32F2F, #FFB74D);
  animation: pulse 2s infinite;
}

.guide-bubble {
  flex: 1;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 24rpx;
  position: relative;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
  animation: slideIn 0.8s ease-out 0.4s both;
  transition: all 0.3s ease;
}

.guide-bubble::before {
  content: '';
  position: absolute;
  left: -16rpx;
  top: 24rpx;
  width: 0;
  height: 0;
  border-top: 16rpx solid transparent;
  border-bottom: 16rpx solid transparent;
  border-right: 16rpx solid #FFFFFF;
  animation: fadeIn 0.8s ease-out 0.6s both;
}

.guide-bubble text {
  font-size: 28rpx;
  color: #333333;
  line-height: 1.6;
  animation: fadeIn 1s ease-out 0.8s both;
}

.guide-bubble:hover {
  transform: translateY(-2rpx);
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.15);
}

.progress-bar {
  height: 20rpx;
  background: rgba(211, 47, 47, 0.1);
  border-radius: 10rpx;
  overflow: hidden;
  margin-bottom: 32rpx;
  animation: slideIn 0.8s ease-out 1s both;
  box-shadow: inset 0 2rpx 4rpx rgba(0, 0, 0, 0.1);
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #D32F2F, #FFB74D);
  transition: width 0.5s ease-out;
  border-radius: 10rpx;
  position: relative;
  overflow: hidden;
}

.progress-fill::after {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.4), transparent);
  animation: shine 1.5s infinite;
}

.game-area {
  flex: 1;
  display: flex;
  flex-direction: column;
  animation: fadeIn 0.8s ease-out 1.2s both;
}

.level-title {
  font-size: 48rpx;
  font-weight: bold;
  color: #D32F2F;
  text-align: center;
  margin-bottom: 16rpx;
  text-shadow: 2rpx 2rpx 4rpx rgba(0, 0, 0, 0.1);
  animation: fadeIn 1s ease-out 1.4s both;
  background: linear-gradient(135deg, #D32F2F, #FFB74D);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.level-desc {
  font-size: 28rpx;
  color: #666666;
  text-align: center;
  margin-bottom: 32rpx;
  animation: fadeIn 1s ease-out 1.6s both;
}

/* 第一关样式 */
.hand-section {
  margin-bottom: 32rpx;
  animation: slideIn 0.8s ease-out 1.8s both;
}

.hand-tiles {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 8rpx;
}

.hand-tiles .mahjong-tile {
  animation: scaleIn 0.6s ease-out both;
}

.pattern-options {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 32rpx;
  animation: slideIn 0.8s ease-out 2s both;
}

.pattern-btn {
  background: #FFFFFF;
  color: #333333;
  border: 4rpx solid #D32F2F;
  border-radius: 50rpx;
  padding: 32rpx;
  font-size: 32rpx;
  font-weight: bold;
  transition: all 0.3s ease;
  width: calc(50% - 8rpx);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
  position: relative;
  overflow: hidden;
}

.pattern-btn::before {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  width: 0;
  height: 0;
  border-radius: 50%;
  background: rgba(211, 47, 47, 0.1);
  transform: translate(-50%, -50%);
  transition: width 0.6s, height 0.6s;
}

.pattern-btn:active::before {
  width: 400rpx;
  height: 400rpx;
}

.pattern-btn:active {
  background: linear-gradient(135deg, #D32F2F, #F44336);
  color: white;
  transform: scale(0.98);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.2);
}

.pattern-btn:hover {
  transform: translateY(-4rpx);
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.15);
  border-color: #FFB74D;
}

.score-display {
  display: flex;
  justify-content: space-around;
  padding: 24rpx;
  background: #FFFFFF;
  border-radius: 24rpx;
  font-size: 32rpx;
  font-weight: bold;
  color: #D32F2F;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
  margin-bottom: 24rpx;
  transition: all 0.3s ease;
  animation: slideIn 0.8s ease-out 2.2s both;
}

.score-display:hover {
  transform: translateY(-2rpx);
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.15);
}

.hint-box {
  display: flex;
  align-items: flex-start;
  background: #E3F2FD;
  border-left: 6rpx solid #2196F3;
  padding: 24rpx;
  border-radius: 16rpx;
  margin-bottom: 32rpx;
  animation: slideIn 0.8s ease-out 2.4s both;
  transition: all 0.3s ease;
}

.hint-box:hover {
  transform: translateY(-2rpx);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.hint-icon {
  font-size: 40rpx;
  margin-right: 16rpx;
  color: #2196F3;
}

.hint-text {
  flex: 1;
  font-size: 26rpx;
  color: #1565C0;
  line-height: 1.6;
}

/* 第二关样式 */
.tile-pool {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 12rpx;
  margin-bottom: 32rpx;
  padding: 24rpx;
  background: #FFFFFF;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
  animation: slideIn 0.8s ease-out 2.6s both;
  transition: all 0.3s ease;
}

.tile-pool:hover {
  transform: translateY(-2rpx);
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.15);
}

.tile-pool .mahjong-tile {
  animation: scaleIn 0.6s ease-out both;
}

.jiangjiang-tile {
  position: relative;
  transition: all 0.3s ease;
  cursor: pointer;
}

.jiangjiang-tile:hover {
  transform: translateY(-4rpx) scale(1.05);
}

.jiangjiang-tile.selected {
  transform: translateY(-10rpx);
  box-shadow: 0 8rpx 16rpx rgba(76, 175, 80, 0.4);
  animation: pulse 1s infinite;
}

.tile-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(76, 175, 80, 0.8);
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  animation: fadeIn 0.4s ease-out;
}

.check-icon {
  font-size: 48rpx;
  color: white;
  font-weight: bold;
  animation: scaleIn 0.6s ease-out;
}

.selection-info {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 16rpx;
  padding: 24rpx;
  background: #FFFFFF;
  border-radius: 24rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
  animation: slideIn 0.8s ease-out 2.8s both;
  transition: all 0.3s ease;
}

.selection-info:hover {
  transform: translateY(-2rpx);
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.15);
}

.info-label {
  font-size: 32rpx;
  color: #666666;
  font-weight: bold;
}

.info-value {
  font-size: 48rpx;
  font-weight: bold;
  color: #FFB74D;
  text-shadow: 2rpx 2rpx 4rpx rgba(0, 0, 0, 0.1);
}

.info-value.complete {
  color: #4CAF50;
  animation: pulse 0.6s ease-in-out;
}

/* 第三关样式 */
.tags-section {
  margin-bottom: 32rpx;
  animation: slideIn 0.8s ease-out 3s both;
}

.section-label {
  display: block;
  font-size: 28rpx;
  color: #666666;
  margin-bottom: 16rpx;
  text-align: center;
  font-weight: bold;
}

.pattern-tags {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 16rpx;
}

.tag-item {
  position: relative;
  padding: 20rpx 40rpx;
  background: #FFFFFF;
  border: 4rpx solid #9E9E9E;
  border-radius: 40rpx;
  font-size: 28rpx;
  color: #666666;
  transition: all 0.3s ease;
  display: flex;
  align-items: center;
  gap: 12rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.tag-item:hover {
  transform: translateY(-4rpx);
  border-color: #D32F2F;
}

.tag-item.selected {
  background: linear-gradient(135deg, #4CAF50, #8BC34A);
  border-color: #4CAF50;
  color: white;
  transform: scale(1.05);
  box-shadow: 0 8rpx 16rpx rgba(76, 175, 80, 0.4);
  animation: pulse 1s infinite;
}

.tag-text {
  font-weight: bold;
}

.tag-check {
  font-size: 32rpx;
  font-weight: bold;
  animation: scaleIn 0.6s ease-out;
}

.multiplier-display {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 16rpx;
  padding: 32rpx;
  background: linear-gradient(135deg, #FF6B6B, #FF8E53);
  border-radius: 24rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 8rpx 16rpx rgba(255, 107, 107, 0.4);
  animation: slideIn 0.8s ease-out 3.2s both;
  transition: all 0.3s ease;
}

.multiplier-display:hover {
  transform: translateY(-4rpx);
  box-shadow: 0 12rpx 24rpx rgba(255, 107, 107, 0.5);
}

.multiplier-label {
  font-size: 32rpx;
  color: white;
  font-weight: bold;
}

.multiplier-value {
  font-size: 56rpx;
  color: white;
  font-weight: bold;
  text-shadow: 2rpx 2rpx 4rpx rgba(0, 0, 0, 0.3);
  animation: bounce 1s infinite;
}

.check-btn {
  width: 100%;
  margin-bottom: 32rpx;
  animation: scaleIn 0.6s ease-out 3.4s both;
}

/* 底部按钮 */
.bottom-actions {
  display: flex;
  gap: 24rpx;
  margin-top: 32rpx;
  animation: slideIn 0.8s ease-out 3.6s both;
}

.bottom-actions button {
  flex: 1;
}
