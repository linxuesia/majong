<!-- 第一章：初入江湖 -->
<view class="container">
  <!-- 辣子雀导师 -->
  <view class="guide-section">
    <image class="guide-avatar" src="https://images.daojia.com/jz/pic/69c729e5f514f9bfc1c6a25b1f91e6ad.jpg" mode="aspectFit"></image>
    <view class="guide-bubble">
      <text>{{guideText}}</text>
    </view>
  </view>

  <!-- 关卡进度 -->
  <view class="progress-bar">
    <view class="progress-fill" style="width: {{progress}}%"></view>
  </view>

  <!-- 游戏区域 -->
  <view class="game-area" wx:if="{{currentLevel === 1}}">
    <view class="level-title">🎯 找茬小游戏</view>
    <view class="level-desc">点击剔除字牌和花牌，只留下万、条、筒！</view>
    
    <view class="tiles-container">
      <view class="tile {{item.removed ? 'removed' : ''}}" 
            wx:for="{{tiles}}" 
            wx:key="id"
            bindtap="onTileTap"
            data-id="{{item.id}}">
        <image class="tile-image" src="{{item.image}}" mode="aspectFit"></image>
      </view>
    </view>

    <view class="score-display">
      <text>得分：{{score}}</text>
      <text>剩余时间：{{timeLeft}}秒</text>
    </view>
  </view>

  <view class="game-area" wx:if="{{currentLevel === 2}}">
    <view class="level-title">🎊 起手胡连连看</view>
    <view class="level-desc">判断这手牌是什么起手胡？</view>
    
    <view class="hand-tiles">
      <view class="mahjong-tile" wx:for="{{handTiles}}" wx:key="index">
        <image class="tile-image" src="{{getTileImage(item)}}" mode="aspectFit"></image>
      </view>
    </view>

    <view class="options">
      <button class="option-btn" 
              wx:for="{{options}}" 
              wx:key="index"
              bindtap="onOptionTap"
              data-answer="{{item}}">
        {{item}}
      </button>
    </view>
  </view>

  <!-- 底部按钮 -->
  <view class="bottom-actions">
    <button class="btn-secondary" bindtap="onBackTap">返回</button>
    <button class="btn-primary" bindtap="onNextTap" disabled="{{!levelCompleted}}">
      {{currentLevel < 2 ? '下一关' : '完成章节'}}
    </button>
  </view>
</view>
