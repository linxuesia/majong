/* 第五章：清一色挑战样式 */
.container {
  min-height: 100vh;
  padding: 32rpx;
  display: flex;
  flex-direction: column;
  background: #f8f9fa;
}

.guide-section {
  display: flex;
  align-items: flex-start;
  margin-bottom: 24rpx;
}

.guide-avatar {
  width: 100rpx;
  height: 100rpx;
  margin-right: 16rpx;
  border-radius: 50%;
  border: 4rpx solid #fff;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.1);
}

.guide-bubble {
  flex: 1;
  background: #fff;
  border-radius: 20rpx;
  padding: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
  position: relative;
}

.guide-bubble text {
  font-size: 28rpx;
  color: #333;
  line-height: 1.5;
}

.progress-bar {
  height: 12rpx;
  background: #eee;
  border-radius: 6rpx;
  margin-bottom: 32rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #ff9800, #f44336);
  transition: width 0.3s ease;
}

.game-area {
  background: #fff;
  border-radius: 32rpx;
  padding: 32rpx;
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.05);
  flex: 1;
  display: flex;
  flex-direction: column;
}

.level-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  text-align: center;
  margin-bottom: 32rpx;
}

.tiles-container {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 8rpx;
  padding: 24rpx;
  background: #f1f8e9;
  border-radius: 16rpx;
  margin-bottom: 40rpx;
}

.tile {
  width: 70rpx !important;
  height: 96rpx !important;
}

/* 九宫格选项 */
.options-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
  margin-bottom: 40rpx;
}

.option-item {
  background: #f5f5f5;
  border-radius: 16rpx;
  padding: 20rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  position: relative;
  border: 4rpx solid transparent;
  transition: all 0.2s ease;
}

.option-item.selected {
  background: #fff3e0;
  border-color: #ff9800;
  transform: scale(1.05);
}

.option-tile {
  width: 80rpx !important;
  height: 110rpx !important;
}

.check-mark {
  position: absolute;
  top: -10rpx;
  right: -10rpx;
  font-size: 32rpx;
  z-index: 10;
}

/* 提交按钮 */
.submit-btn {
  width: 100%;
  height: 100rpx;
  border-radius: 50rpx;
  background: #e0e0e0;
  color: #999;
  font-weight: bold;
  display: flex;
  justify-content: center;
  align-items: center;
  margin-bottom: 32rpx;
  transition: all 0.3s ease;
}

.submit-btn.active {
  background: linear-gradient(135deg, #ff9800, #f44336);
  color: #fff;
  box-shadow: 0 8rpx 20rpx rgba(244, 67, 54, 0.3);
}

.submit-btn:active {
  transform: translateY(2rpx);
  opacity: 0.9;
}

/* 信息栏 */
.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: auto;
  padding-top: 20rpx;
  border-top: 2rpx solid #eee;
}

.score-tag {
  font-size: 28rpx;
  color: #666;
  font-weight: bold;
}

.time-tag {
  font-size: 28rpx;
  color: #666;
  font-family: monospace;
}

.time-tag.urgent {
  color: #f44336;
  animation: blink 1s infinite;
}

@keyframes blink {
  50% { opacity: 0.5; }
}

.bottom-actions {
  margin-top: 32rpx;
}

.btn-secondary {
  background: transparent;
  color: #999;
  font-size: 28rpx;
  border: none;
}
