<!-- 第五章：清一色挑战 -->
<view class="container">
  <!-- 辣子雀导师 -->
  <view class="guide-section">
    <image class="guide-avatar" src="https://images.daojia.com/jz/pic/69c729e5f514f9bfc1c6a25b1f91e6ad.jpg" mode="aspectFit"></image>
    <view class="guide-bubble">
      <text>{{guideText}}</text>
    </view>
  </view>

  <!-- 关卡进度 -->
  <view class="progress-bar">
    <view class="progress-fill" style="width: {{progress}}%"></view>
  </view>

  <!-- 游戏区域 -->
  <view class="game-area">
    <view class="level-title">🀄️ 清一色听牌挑战</view>
    
    <!-- 手牌区域 -->
    <view class="tiles-container">
      <mahjong-tile 
        custom-class="tile" 
        wx:for="{{tiles}}" 
        wx:key="index"
        tile-text="{{item}}"
      ></mahjong-tile>
    </view>

    <!-- 选项区域（1-9号牌） -->
    <view class="options-grid">
      <view class="option-item {{utils.includes(selectedOptions, index + 1) ? 'selected' : ''}}" 
            wx:for="{{options}}" 
            wx:key="index"
            bindtap="onOptionSelect"
            data-index="{{index}}">
        <mahjong-tile 
          tile-text="{{item}}"
          custom-class="option-tile"
        ></mahjong-tile>
        <view class="check-mark" wx:if="{{utils.includes(selectedOptions, index + 1)}}">✅</view>
      </view>
    </view>
    
    <!-- 提交按钮 -->
    <button class="submit-btn {{selectedOptions.length > 0 ? 'active' : ''}}" 
            bindtap="onSubmit"
            disabled="{{selectedOptions.length === 0}}">
      确认胡这些牌 ({{selectedOptions.length}})
    </button>

    <!-- 分数与时间 -->
    <view class="info-row">
      <view class="score-tag">得分：{{score}}</view>
      <view class="time-tag {{timeLeft < 20 ? 'urgent' : ''}}">⏳ {{timeLeft}}s</view>
    </view>
  </view>

  <!-- 底部按钮 -->
  <view class="bottom-actions">
    <button class="btn-secondary" bindtap="onBackTap">退出练习</button>
  </view>
</view>

<!-- 简单的 WXS 辅助函数 -->
<wxs module="utils">
  module.exports = {
    includes: function(array, value) {
      return array.indexOf(value) !== -1;
    }
  }
</wxs>
