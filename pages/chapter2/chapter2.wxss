/* 第二章样式 */
.container {
  min-height: 100vh;
  padding: 32rpx;
  display: flex;
  flex-direction: column;
  animation: fadeIn 0.8s ease-out;
}

.guide-section {
  display: flex;
  align-items: flex-start;
  margin-bottom: 32rpx;
  animation: slideIn 0.8s ease-out 0.2s both;
}

.guide-avatar {
  width: 100rpx;
  height: 100rpx;
  margin-right: 16rpx;
  border-radius: 50%;
  box-shadow: 0 4rpx 16rpx rgba(211, 47, 47, 0.3);
  background: linear-gradient(135deg, #D32F2F, #FFB74D);
  animation: pulse 2s infinite;
}

.guide-bubble {
  flex: 1;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 24rpx;
  position: relative;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
  animation: slideIn 0.8s ease-out 0.4s both;
  transition: all 0.3s ease;
}

.guide-bubble::before {
  content: '';
  position: absolute;
  left: -16rpx;
  top: 24rpx;
  width: 0;
  height: 0;
  border-top: 16rpx solid transparent;
  border-bottom: 16rpx solid transparent;
  border-right: 16rpx solid #FFFFFF;
  animation: fadeIn 0.8s ease-out 0.6s both;
}

.guide-bubble text {
  font-size: 28rpx;
  color: #333333;
  line-height: 1.6;
  animation: fadeIn 1s ease-out 0.8s both;
}

.guide-bubble:hover {
  transform: translateY(-2rpx);
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.15);
}

.progress-bar {
  height: 20rpx;
  background: rgba(211, 47, 47, 0.1);
  border-radius: 10rpx;
  overflow: hidden;
  margin-bottom: 32rpx;
  animation: slideIn 0.8s ease-out 1s both;
  box-shadow: inset 0 2rpx 4rpx rgba(0, 0, 0, 0.1);
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #D32F2F, #FFB74D);
  transition: width 0.5s ease-out;
  border-radius: 10rpx;
  position: relative;
  overflow: hidden;
}

.progress-fill::after {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.4), transparent);
  animation: shine 1.5s infinite;
}

.game-area {
  flex: 1;
  display: flex;
  flex-direction: column;
  animation: fadeIn 0.8s ease-out 1.2s both;
}

.level-title {
  font-size: 48rpx;
  font-weight: bold;
  color: #D32F2F;
  text-align: center;
  margin-bottom: 16rpx;
  text-shadow: 2rpx 2rpx 4rpx rgba(0, 0, 0, 0.1);
  animation: fadeIn 1s ease-out 1.4s both;
  background: linear-gradient(135deg, #D32F2F, #FFB74D);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.level-desc {
  font-size: 28rpx;
  color: #666666;
  text-align: center;
  margin-bottom: 32rpx;
  animation: fadeIn 1s ease-out 1.6s both;
}

/* 第一关样式 */
.hand-section {
  margin-bottom: 32rpx;
  animation: slideIn 0.8s ease-out 1.8s both;
}

.section-label {
  display: block;
  font-size: 28rpx;
  color: #666666;
  margin-bottom: 16rpx;
  font-weight: bold;
}

.hand-tiles {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 8rpx;
}

.hand-tiles .mahjong-tile {
  animation: scaleIn 0.6s ease-out both;
}

.discard-section {
  text-align: center;
  margin-bottom: 32rpx;
  animation: slideIn 0.8s ease-out 2s both;
}

.discard-tile {
  display: inline-block;
  width: 100rpx;
  height: 130rpx;
  background: linear-gradient(135deg, #FF6B6B, #FF8E53);
  border: 4rpx solid #D32F2F;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 16rpx rgba(211, 47, 47, 0.4);
  margin-top: 16rpx;
  transition: all 0.2s ease;
}

.discard-tile:hover {
  transform: translateY(-4rpx) scale(1.05);
  box-shadow: 0 12rpx 24rpx rgba(211, 47, 47, 0.5);
}

.discard-tile.flying {
  animation: fly-in 0.8s ease-out;
}

@keyframes fly-in {
  0% {
    transform: translateY(-200rpx) scale(0.5) rotate(-180deg);
    opacity: 0;
  }
  100% {
    transform: translateY(0) scale(1) rotate(0);
    opacity: 1;
  }
}

.discard-tile text {
  font-size: 40rpx;
  font-weight: bold;
  color: white;
  text-shadow: 2rpx 2rpx 4rpx rgba(0, 0, 0, 0.2);
}

.action-buttons {
  display: flex;
  justify-content: center;
  gap: 24rpx;
  margin-bottom: 32rpx;
  animation: slideIn 0.8s ease-out 2.2s both;
}

.action-btn {
  flex: 1;
  max-width: 180rpx;
  padding: 32rpx 0;
  font-size: 36rpx;
  font-weight: bold;
  border-radius: 50rpx;
  border: none;
  box-shadow: 0 8rpx 16rpx rgba(0, 0, 0, 0.2);
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
}

.action-btn::before {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  width: 0;
  height: 0;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.3);
  transform: translate(-50%, -50%);
  transition: width 0.6s, height 0.6s;
}

.action-btn:active::before {
  width: 300rpx;
  height: 300rpx;
}

.action-btn:active {
  opacity: 0.9;
  transform: scale(0.97);
  box-shadow: 0 4rpx 8rpx rgba(0, 0, 0, 0.3);
}

.action-btn:hover {
  transform: translateY(-4rpx);
  box-shadow: 0 12rpx 24rpx rgba(0, 0, 0, 0.3);
}

.eat-btn {
  background: linear-gradient(135deg, #4CAF50, #66BB6A);
  color: white;
}

.peng-btn {
  background: linear-gradient(135deg, #2196F3, #42A5F5);
  color: white;
}

.pass-btn {
  background: linear-gradient(135deg, #9E9E9E, #BDBDBD);
  color: white;
}

.score-display {
  display: flex;
  justify-content: space-around;
  padding: 24rpx;
  background: #FFFFFF;
  border-radius: 24rpx;
  font-size: 32rpx;
  font-weight: bold;
  color: #D32F2F;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
  margin-bottom: 24rpx;
  transition: all 0.3s ease;
  animation: slideIn 0.8s ease-out 2.4s both;
}

.score-display:hover {
  transform: translateY(-2rpx);
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.15);
}

/* 第二关样式 */
.mahjong-tile.empty {
  background: #F5F5F5;
  border: 4rpx dashed #999;
  transition: all 0.2s ease;
}

.mahjong-tile.empty:hover {
  transform: translateY(-4rpx);
  border-color: #D32F2F;
}

.question {
  font-size: 48rpx;
  color: #999999;
  font-weight: bold;
  animation: bounce 1s infinite;
}

.candidates-section {
  margin-bottom: 32rpx;
  animation: slideIn 0.8s ease-out 2.6s both;
}

.candidate-tiles {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 16rpx;
}

.candidate {
  position: relative;
  cursor: pointer;
  transition: all 0.3s ease;
  display: inline-block;
  border-radius: 16rpx;
  padding: 8rpx;
  background: transparent;
}

.candidate:hover {
  transform: translateY(-4rpx);
}

.candidate.selected {
  background: #FFF3E0;
  border-color: #FFB74D;
  transform: translateY(-10rpx);
  box-shadow: 0 12rpx 24rpx rgba(255, 152, 0, 0.4);
  border-radius: 16rpx;
  padding: 8rpx;
  animation: pulse 1s infinite;
}

.check-mark {
  position: absolute;
  top: -12rpx;
  right: -12rpx;
  width: 48rpx;
  height: 48rpx;
  background: #4CAF50;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
  font-size: 32rpx;
  font-weight: bold;
  box-shadow: 0 4rpx 8rpx rgba(76, 175, 80, 0.4);
  animation: scaleIn 0.4s ease-out;
}

.hint-box {
  display: flex;
  align-items: flex-start;
  background: #E3F2FD;
  border-left: 6rpx solid #2196F3;
  padding: 24rpx;
  border-radius: 16rpx;
  margin-bottom: 32rpx;
  animation: slideIn 0.8s ease-out 2.8s both;
  transition: all 0.3s ease;
}

.hint-box:hover {
  transform: translateY(-2rpx);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.hint-icon {
  font-size: 40rpx;
  margin-right: 16rpx;
  color: #2196F3;
}

.hint-text {
  flex: 1;
  font-size: 26rpx;
  color: #1565C0;
  line-height: 1.6;
}

.check-btn {
  width: 100%;
  margin-bottom: 32rpx;
  animation: scaleIn 0.6s ease-out 3s both;
}

/* 第三关样式 */
.quiz-info {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  margin: 32rpx 0;
  padding: 32rpx;
  background: #FFFFFF;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
  transition: all 0.3s ease;
  animation: slideIn 0.8s ease-out 3.2s both;
}

.quiz-info:hover {
  transform: translateY(-4rpx);
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.15);
}

.quiz-label {
  font-size: 32rpx;
  color: #666666;
  padding: 12rpx 32rpx;
  background: rgba(211, 47, 47, 0.1);
  border-radius: 40rpx;
  font-weight: bold;
}

.quiz-question {
  font-size: 40rpx;
  font-weight: bold;
  color: #D32F2F;
  text-align: center;
  line-height: 1.5;
}

.quiz-buttons {
  display: flex;
  gap: 24rpx;
  margin-bottom: 32rpx;
  animation: slideIn 0.8s ease-out 3.4s both;
}

.quiz-btn {
  flex: 1;
  padding: 48rpx 0;
  font-size: 36rpx;
  font-weight: bold;
  border-radius: 24rpx;
  border: none;
  box-shadow: 0 8rpx 16rpx rgba(0, 0, 0, 0.2);
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
}

.quiz-btn::before {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  width: 0;
  height: 0;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.3);
  transform: translate(-50%, -50%);
  transition: width 0.6s, height 0.6s;
}

.quiz-btn:active::before {
  width: 400rpx;
  height: 400rpx;
}

.quiz-btn:active {
  opacity: 0.9;
  transform: scale(0.97);
  box-shadow: 0 4rpx 8rpx rgba(0, 0, 0, 0.3);
}

.quiz-btn:hover {
  transform: translateY(-4rpx);
  box-shadow: 0 12rpx 24rpx rgba(0, 0, 0, 0.3);
}

.yes-btn {
  background: linear-gradient(135deg, #4CAF50, #8BC34A);
  color: white;
}

.no-btn {
  background: linear-gradient(135deg, #D32F2F, #F44336);
  color: white;
}

/* 底部按钮 */
.bottom-actions {
  display: flex;
  gap: 24rpx;
  margin-top: 32rpx;
  animation: slideIn 0.8s ease-out 3.6s both;
}

.bottom-actions button {
  flex: 1;
}
