/* 第二章样式 */
.container {
  min-height: 100vh;
  padding: 32rpx;
  display: flex;
  flex-direction: column;
}

.guide-section {
  display: flex;
  align-items: flex-start;
  margin-bottom: 32rpx;
}

.guide-avatar {
  width: 100rpx;
  height: 100rpx;
  margin-right: 16rpx;
}

.guide-bubble {
  flex: 1;
  background: white;
  border-radius: 24rpx;
  padding: 24rpx;
  position: relative;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.guide-bubble::before {
  content: '';
  position: absolute;
  left: -16rpx;
  top: 24rpx;
  width: 0;
  height: 0;
  border-top: 16rpx solid transparent;
  border-bottom: 16rpx solid transparent;
  border-right: 16rpx solid white;
}

.guide-bubble text {
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
}

.progress-bar {
  height: 16rpx;
  background: #E0E0E0;
  border-radius: 8rpx;
  overflow: hidden;
  margin-bottom: 32rpx;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #4CAF50, #8BC34A);
  transition: width 0.3s ease;
}

.game-area {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.level-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #D32F2F;
  text-align: center;
  margin-bottom: 16rpx;
}

.level-desc {
  font-size: 28rpx;
  color: #666;
  text-align: center;
  margin-bottom: 32rpx;
}

/* 第一关样式 */
.hand-section {
  margin-bottom: 32rpx;
}

.section-label {
  display: block;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 16rpx;
}

.hand-tiles {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 12rpx;
}

.discard-section {
  text-align: center;
  margin-bottom: 32rpx;
}

.discard-tile {
  display: inline-block;
  width: 100rpx;
  height: 130rpx;
  background: linear-gradient(135deg, #FF6B6B, #FF8E53);
  border: 4rpx solid #D32F2F;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 16rpx rgba(211, 47, 47, 0.4);
  margin-top: 16rpx;
}

.discard-tile.flying {
  animation: fly-in 0.8s ease-out;
}

@keyframes fly-in {
  0% {
    transform: translateY(-200rpx) scale(0.5) rotate(-180deg);
    opacity: 0;
  }
  100% {
    transform: translateY(0) scale(1) rotate(0);
    opacity: 1;
  }
}

.discard-tile text {
  font-size: 40rpx;
  font-weight: bold;
  color: white;
}

.action-buttons {
  display: flex;
  justify-content: center;
  gap: 24rpx;
  margin-bottom: 32rpx;
}

.action-btn {
  flex: 1;
  max-width: 180rpx;
  padding: 32rpx 0;
  font-size: 36rpx;
  font-weight: bold;
  border-radius: 50rpx;
  border: none;
  box-shadow: 0 8rpx 16rpx rgba(0, 0, 0, 0.2);
}

.eat-btn {
  background: linear-gradient(135deg, #4CAF50, #66BB6A);
  color: white;
}

.peng-btn {
  background: linear-gradient(135deg, #2196F3, #42A5F5);
  color: white;
}

.pass-btn {
  background: linear-gradient(135deg, #9E9E9E, #BDBDBD);
  color: white;
}

.score-display {
  display: flex;
  justify-content: space-around;
  padding: 24rpx;
  background: white;
  border-radius: 24rpx;
  font-size: 32rpx;
  font-weight: bold;
  color: #D32F2F;
}

/* 第二关样式 */
.mahjong-tile.empty {
  background: #F5F5F5;
  border: 4rpx dashed #999;
}

.question {
  font-size: 48rpx;
  color: #999;
}

.candidates-section {
  margin-bottom: 32rpx;
}

.candidate-tiles {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 16rpx;
}

.mahjong-tile.candidate {
  position: relative;
  cursor: pointer;
  transition: all 0.3s;
}

.mahjong-tile.candidate.selected {
  background: #FFF3E0;
  border-color: #FF9800;
  transform: translateY(-10rpx);
  box-shadow: 0 12rpx 24rpx rgba(255, 152, 0, 0.4);
}

.check-mark {
  position: absolute;
  top: -12rpx;
  right: -12rpx;
  width: 48rpx;
  height: 48rpx;
  background: #4CAF50;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
  font-size: 32rpx;
  font-weight: bold;
  box-shadow: 0 4rpx 8rpx rgba(76, 175, 80, 0.4);
}

.hint-box {
  display: flex;
  align-items: flex-start;
  background: #E3F2FD;
  border-left: 6rpx solid #2196F3;
  padding: 24rpx;
  border-radius: 12rpx;
  margin-bottom: 32rpx;
}

.hint-icon {
  font-size: 40rpx;
  margin-right: 16rpx;
}

.hint-text {
  flex: 1;
  font-size: 26rpx;
  color: #1565C0;
  line-height: 1.6;
}

.check-btn {
  width: 100%;
  margin-bottom: 32rpx;
}

/* 第三关样式 */
.quiz-info {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  margin: 32rpx 0;
  padding: 32rpx;
  background: white;
  border-radius: 24rpx;
}

.quiz-label {
  font-size: 32rpx;
  color: #666;
  padding: 12rpx 32rpx;
  background: #F5F5F5;
  border-radius: 40rpx;
}

.quiz-question {
  font-size: 40rpx;
  font-weight: bold;
  color: #D32F2F;
}

.quiz-buttons {
  display: flex;
  gap: 24rpx;
  margin-bottom: 32rpx;
}

.quiz-btn {
  flex: 1;
  padding: 48rpx 0;
  font-size: 36rpx;
  font-weight: bold;
  border-radius: 24rpx;
  border: none;
  box-shadow: 0 8rpx 16rpx rgba(0, 0, 0, 0.2);
}

.yes-btn {
  background: linear-gradient(135deg, #4CAF50, #66BB6A);
  color: white;
}

.no-btn {
  background: linear-gradient(135deg, #F44336, #EF5350);
  color: white;
}

/* 底部按钮 */
.bottom-actions {
  display: flex;
  gap: 24rpx;
  margin-top: 32rpx;
}

.bottom-actions button {
  flex: 1;
}
