/* 首页样式 */
.container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  padding: 20rpx 0 40rpx;
  animation: fadeIn 0.8s ease-out;
}

/* 顶部规则按钮 */
.top-settings {
  padding: 0 32rpx 24rpx;
  text-align: right;
  animation: slideIn 0.8s ease-out 0.5s both;
}

.btn-settings {
  background: linear-gradient(135deg, #D32F2F 0%, #F44336 100%);
  color: white;
  border-radius: 50rpx;
  padding: 16rpx 32rpx;
  font-size: 28rpx;
  font-weight: bold;
  box-shadow: 0 8rpx 16rpx rgba(211, 47, 47, 0.3);
  border: none;
  position: relative;
  overflow: hidden;
  transition: all 0.3s ease;
  animation: scaleIn 0.6s ease-out 0.7s both;
}

.btn-settings:hover {
  transform: translateY(-2rpx);
  box-shadow: 0 12rpx 24rpx rgba(211, 47, 47, 0.4);
}

.btn-settings:active {
  opacity: 0.9;
  transform: scale(0.97);
  box-shadow: 0 4rpx 8rpx rgba(211, 47, 47, 0.4);
}

.title-section {
  text-align: center;
  padding: 60rpx 0;
  animation: slideIn 0.8s ease-out 0.2s both;
}

.mascot {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 20rpx;
  animation: scaleIn 1s ease-out 0.4s both, float 3s ease-in-out infinite 1s;
  border-radius: 50%;
  box-shadow: 0 8rpx 24rpx rgba(211, 47, 47, 0.3);
  background: linear-gradient(135deg, #D32F2F, #FFB74D);
}

.game-title {
  display: block;
  font-size: 64rpx;
  font-weight: bold;
  color: #D32F2F;
  margin-bottom: 12rpx;
  text-shadow: 2rpx 2rpx 4rpx rgba(0, 0, 0, 0.1);
  animation: fadeIn 1s ease-out 0.6s both;
  background: linear-gradient(135deg, #D32F2F, #FFB74D);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.game-subtitle {
  display: block;
  font-size: 36rpx;
  color: #666666;
  animation: fadeIn 1s ease-out 0.8s both;
}

.chapters-section {
  flex: 1;
  padding: 0 32rpx;
  animation: slideIn 0.8s ease-out 1s both;
}

.chapter-card {
  display: flex;
  align-items: center;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
  animation: slideIn 0.6s ease-out both;
}

.chapter-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 4rpx;
  background: linear-gradient(90deg, #D32F2F, #FFB74D);
}

.chapter-card:nth-child(1) {
  animation-delay: 1.2s;
}

.chapter-card:nth-child(2) {
  animation-delay: 1.3s;
}

.chapter-card:nth-child(3) {
  animation-delay: 1.4s;
}

.chapter-card:nth-child(4) {
  animation-delay: 1.5s;
}

.chapter-card:nth-child(5) {
  animation-delay: 1.6s;
}

.chapter-card.unlocked:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.2);
}

.chapter-card.unlocked:hover {
  transform: translateY(-4rpx) scale(1.02);
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.15);
}

.chapter-card.locked {
  opacity: 0.5;
  filter: grayscale(0.8);
}

.chapter-icon {
  font-size: 64rpx;
  margin-right: 24rpx;
  color: #D32F2F;
  transition: all 0.3s ease;
}

.chapter-card:hover .chapter-icon {
  transform: scale(1.2) rotate(10deg);
  color: #FFB74D;
}

.chapter-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.chapter-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 8rpx;
  transition: color 0.2s ease;
}

.chapter-card:hover .chapter-title {
  color: #D32F2F;
}

.chapter-desc {
  font-size: 28rpx;
  color: #999999;
  line-height: 1.5;
}

.chapter-status {
  font-size: 48rpx;
  color: #FFB74D;
  transition: all 0.3s ease;
}

.chapter-card:hover .chapter-status {
  transform: scale(1.1);
}

.bottom-buttons {
  display: flex;
  justify-content: center;
  padding: 32rpx;
  gap: 24rpx;
  animation: slideIn 0.8s ease-out 1.8s both;
}

.bottom-buttons button {
  width: 100%;
  max-width: 600rpx;
  animation: scaleIn 0.6s ease-out 2s both;
}

/* 分享按钮 */
.share-section {
  padding: 0 32rpx 24rpx;
  animation: slideIn 0.8s ease-out 2.2s both;
}

.btn-share {
  background: linear-gradient(135deg, #FFB74D 0%, #FF9800 100%);
  color: white;
  border-radius: 50rpx;
  padding: 24rpx 48rpx;
  font-size: 32rpx;
  font-weight: bold;
  box-shadow: 0 8rpx 24rpx rgba(255, 183, 77, 0.4);
  border: none;
  position: relative;
  overflow: hidden;
  transition: all 0.3s ease;
  width: 100%;
  animation: scaleIn 0.6s ease-out 2.4s both;
}

.btn-share:hover {
  transform: translateY(-2rpx);
  box-shadow: 0 12rpx 32rpx rgba(255, 183, 77, 0.5);
}

.btn-share:active {
  opacity: 0.9;
  transform: scale(0.97);
  box-shadow: 0 4rpx 12rpx rgba(255, 183, 77, 0.4);
}

/* 开发模式工具栏 */
.dev-toolbar {
  margin: 32rpx;
  padding: 24rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 24rpx;
  box-shadow: 0 8rpx 16rpx rgba(102, 126, 234, 0.3);
  animation: fadeIn 1s ease-out 2.2s both;
}

.dev-title {
  font-size: 28rpx;
  font-weight: bold;
  color: white;
  text-align: center;
  margin-bottom: 16rpx;
}

.dev-buttons {
  display: flex;
  gap: 12rpx;
}

.dev-btn {
  flex: 1;
  padding: 16rpx 0;
  font-size: 24rpx;
  background: rgba(255, 255, 255, 0.2);
  color: white;
  border: 2rpx solid rgba(255, 255, 255, 0.5);
  border-radius: 12rpx;
  transition: all 0.2s ease;
  position: relative;
  overflow: hidden;
}

.dev-btn::before {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  width: 0;
  height: 0;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
  transform: translate(-50%, -50%);
  transition: width 0.6s, height 0.6s;
}

.dev-btn:active::before {
  width: 200rpx;
  height: 200rpx;
}

.dev-btn:active {
  background: rgba(255, 255, 255, 0.3);
  transform: scale(0.98);
}

.dev-btn:hover {
  background: rgba(255, 255, 255, 0.25);
  transform: translateY(-2rpx);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.2);
}
