/* 记账本首页样式 - 复古手绘风格 */
page {
  background-color: #FFF9F0;
  background-image: 
    radial-gradient(#E8D4B4 1px, transparent 1px),
    radial-gradient(#E8D4B4 1px, transparent 1px);
  background-size: 40rpx 40rpx;
  background-position: 0 0, 20rpx 20rpx;
  background-attachment: fixed;
}

.container {
  min-height: 100vh;
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
}

/* 用户信息区域 */
.user-info-section {
  background-color: #FFFDF5;
  border-radius: 2rpx;
  padding: 28rpx;
  border: 4rpx dashed #8B6914;
  position: relative;
}

.user-info-section::before {
  content: '';
  position: absolute;
  top: 8rpx;
  left: 8rpx;
  right: 8rpx;
  bottom: 8rpx;
  border: 2rpx dashed #C4A574;
  pointer-events: none;
}

.user-info {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.user-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-right: 24rpx;
  border: 3rpx solid #8B6914;
  background-color: #FFF8E7;
}

.user-detail {
  display: flex;
  flex-direction: column;
}

.user-nickname {
  font-size: 32rpx;
  font-weight: bold;
  color: #5D4E37;
  font-family: "Comic Sans MS", "Marker Felt", cursive;
}

.user-stats {
  font-size: 24rpx;
  color: #A0826D;
  margin-top: 4rpx;
  font-style: italic;
}

.btn-authorize {
  width: 100%;
  background: linear-gradient(135deg, #CD853F, #B87333);
  color: white;
  border-radius: 8rpx;
  padding: 24rpx;
  font-size: 32rpx;
  font-weight: bold;
  border: 4rpx double #8B6914;
  font-family: "Comic Sans MS", "Marker Felt", cursive;
  text-shadow: 2rpx 2rpx 0px rgba(0,0,0,0.2);
}

.btn-authorize:active {
  background: linear-gradient(135deg, #B87333, #CD853F);
  transform: scale(0.98);
}

/* 核心操作区 */
.action-cards {
  display: flex;
  flex-direction: row;
  gap: 32rpx;
}

.action-card {
  flex: 1;
  background-color: #FFFAF0;
  border-radius: 2rpx;
  padding: 36rpx 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  border: 4rpx dotted #8B6914;
  position: relative;
  transition: all 0.2s ease;
}

.action-card::after {
  content: '';
  position: absolute;
  top: 6rpx;
  left: 6rpx;
  right: 6rpx;
  bottom: 6rpx;
  border: 2rpx dotted #C4A574;
  pointer-events: none;
}

.action-card:active {
  transform: scale(0.95);
  background-color: #FFE4B5;
}

.create-card {
  transform: rotate(-1.5deg);
}

.join-card {
  transform: rotate(1.5deg);
}

.card-icon {
  font-size: 72rpx;
  margin-bottom: 20rpx;
  filter: drop-shadow(3rpx 3rpx 0px rgba(139, 105, 20, 0.3));
}

.create-card .card-icon {
  color: #CD853F;
}

.join-card .card-icon {
  color: #6B8E23;
}

.card-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #5D4E37;
  margin-bottom: 8rpx;
  font-family: "Comic Sans MS", "Marker Felt", cursive;
}

.card-subtitle {
  font-size: 24rpx;
  color: #A0826D;
  font-style: italic;
}

/* 房间输入区域 */
.room-input-section {
  background-color: #FFFAF0;
  border-radius: 4rpx;
  padding: 40rpx 32rpx;
  border: 4rpx double #8B6914;
  position: relative;
  margin-bottom: 16rpx;
}

.room-input-section::before {
  content: '📝';
  position: absolute;
  top: -20rpx;
  left: 50%;
  transform: translateX(-50%);
  background-color: #FFF9F0;
  padding: 0 16rpx;
  font-size: 32rpx;
  z-index: 1;
}

.form-group {
  margin-bottom: 36rpx;
}

.form-label {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #5D4E37;
  margin-bottom: 20rpx;
  font-family: "Comic Sans MS", "Marker Felt", cursive;
  text-align: center;
}

.form-input {
  width: 100%;
  background-color: #FFF8E7;
  border-radius: 4rpx;
  padding: 0 20rpx;
  font-size: 30rpx;
  color: #5D4E37;
  border: 4rpx solid #8B6914;
  box-sizing: border-box;
  font-family: "Helvetica Neue", Arial, sans-serif;
  text-align: center;
  height: 110rpx;
  line-height: 110rpx;
}

.form-input::placeholder {
  color: #C4A574;
  font-style: normal;
  font-size: 30rpx;
  font-family: "Helvetica Neue", Arial, sans-serif;
  line-height: 110rpx;
}

.form-input:focus {
  outline: none;
  background-color: #FFE4B5;
  box-shadow: 4rpx 4rpx 0px #8B6914;
}

.input-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 28rpx;
}

.btn-join {
  flex: 1;
  background: linear-gradient(135deg, #CD853F, #B87333);
  color: white;
  border-radius: 4rpx;
  padding: 28rpx 20rpx;
  font-size: 32rpx;
  font-weight: bold;
  border: 3rpx solid #8B6914;
  font-family: "Comic Sans MS", "Marker Felt", cursive;
  text-shadow: 2rpx 2rpx 0px rgba(0,0,0,0.2);
}

.btn-join:active {
  background: linear-gradient(135deg, #B87333, #CD853F);
  transform: scale(0.98);
}

.btn-cancel {
  flex: 1;
  background-color: #FFF8E7;
  color: #8B6914;
  border-radius: 4rpx;
  padding: 28rpx 20rpx;
  font-size: 32rpx;
  border: 3rpx dashed #8B6914;
  font-family: "Comic Sans MS", "Marker Felt", cursive;
}

.btn-cancel:active {
  background-color: #FFE4B5;
  transform: scale(0.98);
}

/* 历史房间区域 */
.history-section {
  background-color: #FFFAF0;
  border-radius: 2rpx;
  padding: 32rpx;
  border: 4rpx dashed #8B6914;
  flex: 1;
  min-height: 200rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #5D4E37;
  margin-bottom: 24rpx;
  display: block;
  font-family: "Comic Sans MS", "Marker Felt", cursive;
  text-decoration: underline;
  text-decoration-style: wavy;
  text-decoration-color: #CD853F;
  text-decoration-thickness: 3rpx;
}

.empty-state {
  text-align: center;
  padding: 56rpx 0;
}

.empty-illustration {
  font-size: 96rpx;
  margin-bottom: 24rpx;
  opacity: 0.6;
  transform: rotate(-8deg);
  filter: grayscale(30%);
}

.empty-text {
  font-size: 28rpx;
  color: #A0826D;
  font-style: italic;
  font-family: "Comic Sans MS", "Marker Felt", cursive;
}

.history-list {
  margin-top: 8rpx;
}

.history-item {
  background-color: #FFF8E7;
  border-radius: 0rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  border: 3rpx solid #C4A574;
  transition: all 0.2s ease;
  transform: rotate(-0.8deg);
  position: relative;
}

.history-item::before {
  content: '📌';
  position: absolute;
  top: -12rpx;
  left: 50%;
  transform: translateX(-50%);
  font-size: 24rpx;
  background-color: #FFF8E7;
  padding: 0 8rpx;
}

.history-item:nth-child(even) {
  transform: rotate(0.8deg);
}

.history-item:nth-child(even)::before {
  content: '📎';
}

.history-item:active {
  transform: rotate(0deg) scale(0.98);
  background-color: #FFE4B5;
}

.room-name {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: #5D4E37;
  margin-bottom: 8rpx;
  font-family: "Comic Sans MS", "Marker Felt", cursive;
}

.room-time {
  display: block;
  font-size: 24rpx;
  color: #A0826D;
  font-style: italic;
}

/* 本地模式区域 */
.local-mode-section {
  margin-top: auto;
  padding-top: 16rpx;
}

.btn-local {
  width: 100%;
  background-color: #FFF8E7;
  color: #8B6914;
  border-radius: 2rpx;
  padding: 28rpx;
  font-size: 28rpx;
  font-weight: bold;
  border: 4rpx dashed #CD853F;
  font-family: "Comic Sans MS", "Marker Felt", cursive;
}

.btn-local:active {
  background-color: #FFE4B5;
  transform: scale(0.98);
}

/* 动画效果 */
@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

.fadeIn {
  animation: fadeIn 0.4s ease-out;
}

@keyframes slideIn {
  from { transform: translateY(20rpx); opacity: 0; }
  to { transform: translateY(0); opacity: 1; }
}

.slideIn {
  animation: slideIn 0.4s ease-out;
}

@keyframes wiggle {
  0%, 100% { transform: rotate(-1deg); }
  50% { transform: rotate(1deg); }
}

.wiggle {
  animation: wiggle 0.5s ease-in-out infinite;
}

/* 响应式设计 */
@media (max-width: 375px) {
  .container {
    padding: 16rpx;
    gap: 24rpx;
  }
  
  .action-cards {
    flex-direction: column;
  }
  
  .card-icon {
    font-size: 64rpx;
  }
  
  .card-title {
    font-size: 28rpx;
  }
  
  .card-subtitle {
    font-size: 22rpx;
  }
}
