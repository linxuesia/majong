<view class="container">
  <view class="header">
    <text class="title">V2 全牌面调试预览</text>
    <text class="subtitle">基于新版 DemChing 精灵图 (3D CSS 外框)</text>
  </view>

  <view class="table-preview">
    <view class="section-title">🀄️ 全牌面集合 (34张)</view>
    <view class="all-tiles-grid">
      <view class="tile-item" wx:for="{{allTiles}}" wx:key="index">
        <mahjong-tile-v2 tile-text="{{item}}" width="70" height="96"></mahjong-tile-v2>
        <text class="tile-label">{{item}}</text>
      </view>
    </view>
  </view>

  <view class="interactive-test">
    <view class="section-title">👆 选中动效测试</view>
    <view class="test-item" bindtap="toggleSelect">
      <mahjong-tile-v2 tile-text="中" selected="{{isSelected}}" width="120" height="160"></mahjong-tile-v2>
      <text>点击测试上浮效果</text>
    </view>
  </view>
</view>
