.container { padding: 24rpx; background: #f0f2f5; min-height: 100vh; }
.header { text-align: center; margin-bottom: 32rpx; }
.title { font-size: 36rpx; font-weight: bold; color: #1a1a1a; }
.subtitle { font-size: 24rpx; color: #666; }

.table-preview {
  background: radial-gradient(#2e7d32, #1b5e20);
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.2);
  margin-bottom: 32rpx;
}

.section-title {
  color: #fff;
  font-size: 28rpx;
  margin-bottom: 24rpx;
  font-weight: bold;
}

.all-tiles-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  justify-content: flex-start;
}

.tile-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.tile-label {
  color: rgba(255,255,255,0.6);
  font-size: 20rpx;
}

.interactive-test {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.test-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}
