/* 全局样式变量 */
.edit-item-page.data-v-785c64c3 {
  min-height: 100vh;
  background-color: #F5F5F5;
  padding-bottom: 160rpx;
}
.edit-item-page__loading.data-v-785c64c3 {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 60vh;
  color: #999999;
  font-size: 28rpx;
}
.edit-item-page__form.data-v-785c64c3 {
  padding: 24rpx;
}
.edit-item-page__field.data-v-785c64c3 {
  background-color: #ffffff;
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}
.edit-item-page__label.data-v-785c64c3 {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 16rpx;
}
.edit-item-page__required.data-v-785c64c3 {
  color: #FF6B6B;
}
.edit-item-page__input.data-v-785c64c3 {
  width: 100%;
  height: 80rpx;
  border: 2rpx solid #EEEEEE;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #333333;
  box-sizing: border-box;
}
.edit-item-page__input.data-v-785c64c3:focus {
  border-color: #FF6B6B;
}
.edit-item-page__textarea.data-v-785c64c3 {
  width: 100%;
  min-height: 160rpx;
  border: 2rpx solid #EEEEEE;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  color: #333333;
  box-sizing: border-box;
}
.edit-item-page__textarea.data-v-785c64c3:focus {
  border-color: #FF6B6B;
}
.edit-item-page__image-upload.data-v-785c64c3 {
  width: 200rpx;
  height: 200rpx;
  border: 2rpx dashed #DDDDDD;
  border-radius: 16rpx;
  overflow: hidden;
}
.edit-item-page__image-preview.data-v-785c64c3 {
  width: 100%;
  height: 100%;
}
.edit-item-page__image-placeholder.data-v-785c64c3 {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background-color: #F9F9F9;
}
.edit-item-page__image-icon.data-v-785c64c3 {
  font-size: 56rpx;
  color: #CCCCCC;
  line-height: 1;
}
.edit-item-page__image-text.data-v-785c64c3 {
  font-size: 24rpx;
  color: #999999;
  margin-top: 8rpx;
}
.edit-item-page__price-input-wrap.data-v-785c64c3 {
  display: flex;
  align-items: center;
  border: 2rpx solid #EEEEEE;
  border-radius: 16rpx;
  padding: 0 24rpx;
  height: 80rpx;
  box-sizing: border-box;
}
.edit-item-page__price-input-wrap.data-v-785c64c3:focus-within {
  border-color: #FF6B6B;
}
.edit-item-page__price-symbol.data-v-785c64c3 {
  font-size: 32rpx;
  font-weight: 600;
  color: #FF6B6B;
  margin-right: 12rpx;
}
.edit-item-page__price-input.data-v-785c64c3 {
  flex: 1;
  height: 100%;
  font-size: 28rpx;
  color: #333333;
}
.edit-item-page__category-wrap.data-v-785c64c3, .edit-item-page__priority-wrap.data-v-785c64c3 {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}
.edit-item-page__category-tag.data-v-785c64c3, .edit-item-page__priority-tag.data-v-785c64c3 {
  padding: 12rpx 28rpx;
  border-radius: 999rpx;
  font-size: 26rpx;
  color: #666666;
  background-color: #F5F5F5;
  border: 2rpx solid transparent;
  transition: all 0.2s;
}
.edit-item-page__category-tag--active.data-v-785c64c3, .edit-item-page__priority-tag--active.data-v-785c64c3 {
