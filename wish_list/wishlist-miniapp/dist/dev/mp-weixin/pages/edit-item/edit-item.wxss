}
.edit-item-page__footer.data-v-785c64c3 {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx;
  background-color: #ffffff;
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.06);
  z-index: 100;
}
.edit-item-page__submit-btn.data-v-785c64c3 {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  background: linear-gradient(135deg, #FF6B6B, #FF8E8E);
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 48rpx;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 107, 0.3);
}
.edit-item-page__submit-btn.data-v-785c64c3::after {
  border: none;
}
.edit-item-page__submit-btn.data-v-785c64c3:active {
  opacity: 0.9;
}