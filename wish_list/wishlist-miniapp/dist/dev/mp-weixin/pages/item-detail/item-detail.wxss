/* 全局样式变量 */
.detail-page.data-v-c1cbfc61 {
  min-height: 100vh;
  background-color: #F5F5F5;
  padding-bottom: 200rpx;
}
.detail-page__loading.data-v-c1cbfc61, .detail-page__error.data-v-c1cbfc61 {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 60vh;
  color: #999999;
  font-size: 28rpx;
}
.detail-page__back-btn.data-v-c1cbfc61 {
  margin-top: 32rpx;
  padding: 16rpx 48rpx;
  background-color: #FF6B6B;
  color: #ffffff;
  font-size: 28rpx;
  border-radius: 44rpx;
  border: none;
}
.detail-page__back-btn.data-v-c1cbfc61::after {
  border: none;
}
.detail-page__image-section.data-v-c1cbfc61 {
  position: relative;
  width: 100%;
  height: 600rpx;
  background-color: #EEEEEE;
}
.detail-page__swiper.data-v-c1cbfc61 {
  width: 100%;
  height: 100%;
}
.detail-page__swiper-image.data-v-c1cbfc61 {
  width: 100%;
  height: 100%;
}
.detail-page__image-count.data-v-c1cbfc61 {
  position: absolute;
  bottom: 20rpx;
  right: 20rpx;
  padding: 4rpx 16rpx;
  background-color: rgba(0, 0, 0, 0.5);
  color: #ffffff;
  font-size: 22rpx;
  border-radius: 20rpx;
}
.detail-page__info.data-v-c1cbfc61 {
  background-color: #ffffff;
  padding: 32rpx;
  margin-top: -24rpx;
  border-radius: 32rpx 32rpx 0 0;
  position: relative;
}
.detail-page__price-row.data-v-c1cbfc61 {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}
.detail-page__price.data-v-c1cbfc61 {
  font-size: 48rpx;
  font-weight: 700;
  color: #FF6B6B;
}
.detail-page__status-tag.data-v-c1cbfc61 {
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: 500;
}
.detail-page__status-tag--active.data-v-c1cbfc61 {
  background-color: #F0F5FF;
  color: #1890FF;
}
.detail-page__status-tag--claimed.data-v-c1cbfc61 {
  background-color: #FFF7E6;
  color: #FAAD14;
}
.detail-page__status-tag--completed.data-v-c1cbfc61 {
  background-color: #F6FFED;
  color: #52C41A;
}
.detail-page__status-tag--cancelled.data-v-c1cbfc61 {
  background-color: #F5F5F5;
  color: #999999;
}
.detail-page__title.data-v-c1cbfc61 {
  font-size: 34rpx;
  font-weight: 600;
  color: #333333;
  line-height: 1.5;
  margin-bottom: 12rpx;
}
.detail-page__desc.data-v-c1cbfc61 {
  font-size: 28rpx;
  color: #666666;
  line-height: 1.6;
  margin-bottom: 24rpx;
}
.detail-page__tags.data-v-c1cbfc61 {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 24rpx;
}
.detail-page__tag.data-v-c1cbfc61 {
  padding: 8rpx 20rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  color: #666666;
  background-color: #F5F5F5;
}
.detail-page__tag--link.data-v-c1cbfc61 {
  color: #1890FF;
  background-color: #F0F5FF;
}
.detail-page__claimer-info.data-v-c1cbfc61 {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background-color: #FFF7E6;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
}
.detail-page__claimer-label.data-v-c1cbfc61 {
  font-size: 26rpx;
  color: #999999;
  margin-right: 16rpx;
}
.detail-page__claimer-name.data-v-c1cbfc61 {
  font-size: 28rpx;
  font-weight: 500;
  color: #FAAD14;
}
.detail-page__time.data-v-c1cbfc61 {
  font-size: 24rpx;
  color: #999999;
}
.detail-page__claim-section.data-v-c1cbfc61 {
  padding: 32rpx;
  background-color: #ffffff;
  margin-top: 24rpx;
}
.detail-page__actions.data-v-c1cbfc61 {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  gap: 24rpx;
  padding: 24rpx;
  background-color: #ffffff;
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.06);
  z-index: 100;
}
.detail-page__action-btn.data-v-c1cbfc61 {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 500;
  border: none;
}
.detail-page__action-btn.data-v-c1cbfc61::after {
  border: none;
}
.detail-page__action-btn--edit.data-v-c1cbfc61 {
  background-color: #ffffff;
  color: #FF6B6B;
  border: 2rpx solid #FF6B6B;
}
.detail-page__action-btn--delete.data-v-c1cbfc61 {
  background-color: #F5F5F5;
  color: #999999;
}