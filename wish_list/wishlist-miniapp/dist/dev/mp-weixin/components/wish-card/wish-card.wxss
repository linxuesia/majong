/* 全局样式变量 */
.wish-card.data-v-495bc0dc {
  border-radius: 20rpx;
  overflow: hidden;
  background-color: #ffffff;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}
.wish-card.data-v-495bc0dc:active {
  transform: scale(0.97);
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}
.wish-card__image-wrap.data-v-495bc0dc {
  position: relative;
  width: 100%;
  padding-top: 120%;
  overflow: hidden;
}
.wish-card__image.data-v-495bc0dc {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-color: #f0ece6;
}
.wish-card__overlay.data-v-495bc0dc {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 55%;
  background: linear-gradient(to top, rgba(0, 0, 0, 0.55) 0%, rgba(0, 0, 0, 0.15) 60%, transparent 100%);
  pointer-events: none;
}
.wish-card__float.data-v-495bc0dc {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx;
  z-index: 2;
}
.wish-card__title.data-v-495bc0dc {
  font-size: 26rpx;
  font-weight: 600;
  color: #ffffff;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  text-shadow: 0 1rpx 4rpx rgba(0, 0, 0, 0.2);
  margin-bottom: 10rpx;
}
.wish-card__meta.data-v-495bc0dc {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.wish-card__price.data-v-495bc0dc {
  font-size: 28rpx;
  font-weight: 700;
  color: #ffffff;
  text-shadow: 0 1rpx 4rpx rgba(0, 0, 0, 0.2);
}
.wish-card__price--free.data-v-495bc0dc {
  font-size: 22rpx;
  font-weight: 500;
  color: rgba(255, 255, 255, 0.85);
  background-color: rgba(255, 255, 255, 0.2);
  padding: 2rpx 14rpx;
  border-radius: 20rpx;
}
.wish-card__claimer-tag.data-v-495bc0dc {
  font-size: 20rpx;
  color: #ffffff;
  background-color: rgba(250, 173, 20, 0.85);
  padding: 2rpx 14rpx;
  border-radius: 20rpx;
  backdrop-filter: blur(4px);
}
.wish-card__status-badge.data-v-495bc0dc {
  position: absolute;
  top: 16rpx;
  left: 16rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-size: 20rpx;
  font-weight: 500;
  color: #ffffff;
  backdrop-filter: blur(8px);
  z-index: 3;
}
.wish-card__status-badge--claimed.data-v-495bc0dc {
  background-color: rgba(250, 173, 20, 0.85);
}
.wish-card__status-badge--completed.data-v-495bc0dc {
  background-color: rgba(82, 196, 26, 0.85);
}
.wish-card__wish-tag.data-v-495bc0dc {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-size: 20rpx;
  font-weight: 500;
  color: #ffffff;
  background-color: rgba(255, 107, 107, 0.85);
  backdrop-filter: blur(8px);
  z-index: 3;
}